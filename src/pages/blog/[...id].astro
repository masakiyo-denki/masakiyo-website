---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const siteUrl = 'https://www.masakiyo-denki.com';
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.date.toISOString(),
  "image": post.data.heroImage ? `${siteUrl}${post.data.heroImage}` : `${siteUrl}/images/shop-exterior.jpg`,
  "author": {
    "@type": "Organization",
    "name": "合資会社 正清電器",
    "url": siteUrl
  },
  "publisher": {
    "@type": "Organization",
    "name": "合資会社 正清電器",
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/images/logo.jpg`
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${siteUrl}/blog/${post.id}`
  }
};
---

<Layout
  title={`${post.data.title} | 正清電器`}
  description={post.data.description}
  canonicalPath={`/blog/${post.id}`}
  ogImage={post.data.heroImage ?? post.data.image}
>
  <div class="max-w-3xl mx-auto px-4 py-16">
    <a href="/blog" class="text-sm text-[var(--color-primary)] hover:underline mb-6 inline-block">← お知らせ一覧へ</a>
    <article>
      <div class="flex items-center gap-3 mb-3">
        <time class="text-sm text-gray-400">
          {post.data.date.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {post.data.category && (
          <span class="text-xs font-bold text-[var(--color-primary)] bg-blue-50 px-2 py-0.5 rounded">{post.data.category}</span>
        )}
      </div>
      <h1 class="text-2xl md:text-3xl font-bold text-[var(--color-primary)] mb-6">{post.data.title}</h1>

      {(post.data.heroImage || post.data.image) && !post.body?.includes('<!-- body-images -->') && (
        <div class="mb-8 rounded-xl overflow-hidden">
          <img
            src={post.data.heroImage ?? post.data.image}
            alt={post.data.imageAlt ?? post.data.title}
            class="w-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
      )}

      <div class="prose prose-blue max-w-none text-gray-700 leading-relaxed">
        <Content />
      </div>
    </article>

    <div class="mt-12 pt-8 border-t border-gray-200">
      <a href="/blog" class="text-sm text-[var(--color-primary)] hover:underline">← お知らせ一覧へ戻る</a>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
</Layout>
